# rustfs-exporter environment — copied to /etc/rustfs-mon/exporter.env
# Permissions: 0640 root:rustfs-mon

# ----- Target rustfs -----
RUSTFS_ENDPOINT=https://10.0.50.15:9000
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=VMware1!
RUSTFS_REGION=us-east-1

# ----- Exporter bind + cadence -----
RUSTFS_EXPORTER_LISTEN=:9090
RUSTFS_EXPORTER_SCRAPE_INTERVAL=30s

# ----- TLS -----
# RHEL 9 / Rocky 9 system CA bundle:
RUSTFS_CA_CERT=/etc/pki/tls/certs/ca-bundle.crt
# (On Debian/Ubuntu hosts, use /etc/ssl/certs/ca-certificates.crt instead.)
# Set to true ONLY for ad-hoc debugging against self-signed certs:
RUSTFS_TLS_SKIP_VERIFY=false