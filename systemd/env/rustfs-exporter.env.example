# rustfs-exporter environment — copied to /etc/rustfs-mon/exporter.env
# Permissions: 0640 root:rustfs-mon
#
# 配置模式 2 选 1：
#
#   A. 多 rustfs 模式（推荐）：用 RUSTFS_TARGETS_JSON 配置多个目标
#      所有指标都带 instance=<name> 标签，dashboard 用模板变量筛选
#
#   B. 单 rustfs 模式（向后兼容）：用 RUSTFS_ENDPOINT + 凭证
#      所有指标没有 instance 标签（默认 "default"）

# ============================================================
# 模式 A：多 rustfs
# ============================================================
RUSTFS_TARGETS_JSON='[
  {
    "name": "source",
    "endpoint": "https://10.0.50.15:9000",
    "access_key": "admin",
    "secret_key": "VMware1!",
    "tls_skip_verify": true
  },
  {
    "name": "target",
    "endpoint": "https://10.0.50.18:9000",
    "access_key": "rustfsadmin",
    "secret_key": "rustfsadmin"
  }
]'

# ============================================================
# 模式 B：单 rustfs（如果 RUSTFS_TARGETS_JSON 留空，用下面这些）
# ============================================================
# RUSTFS_ENDPOINT=https://10.0.50.15:9000
# RUSTFS_ACCESS_KEY=admin
# RUSTFS_SECRET_KEY=VMware1!
# RUSTFS_REGION=us-east-1

# 单目标模式的 TLS：
# RHEL 9 / Rocky 9 系统 CA bundle:
# RUSTFS_CA_CERT=/etc/pki/tls/certs/ca-bundle.crt
# (Debian/Ubuntu: /etc/ssl/certs/ca-certificates.crt)
# 仅调试用：
# RUSTFS_TLS_SKIP_VERIFY=false

# ============================================================
# 通用：exporter bind + 抓取频率
# ============================================================
RUSTFS_EXPORTER_LISTEN=:9090
RUSTFS_EXPORTER_SCRAPE_INTERVAL=30s