# ============================================================
# RustFS Monitoring Stack — .env template
# ============================================================
# 复制本文件为 .env 后填入真实值：
#   cp .env.example .env && vim .env
#
# 部署在能直连 rustfs 的机器上（同一 VPC / VPN / 同主机）。

# ============================================================
# Targets — 单 rustfs 或多 rustfs
# ============================================================
# 多 rustfs 模式（推荐）：用 RUSTFS_TARGETS_JSON 一次配置多个
#   - 每个目标有独立 endpoint + 凭证 + TLS 设置
#   - 所有指标都带 instance=<name> 标签，便于 dashboard 区分
#   - 一个 exporter 同时抓多个 rustfs
#
# 单 rustfs 模式（向后兼容）：用 RUSTFS_ENDPOINT + 凭证
#
# ---------------------- 多 rustfs 配置 ----------------------
# 例子：源端 + 目标端
RUSTFS_TARGETS_JSON=[
  {
    "name": "source",
    "endpoint": "https://10.0.50.15:9000",
    "access_key": "admin",
    "secret_key": "VMware1!",
    "tls_skip_verify": true
  },
  {
    "name": "target",
    "endpoint": "https://10.0.50.18:9000",
    "access_key": "rustfsadmin",
    "secret_key": "rustfsadmin"
  }
]

# ---------------------- 单 rustfs 配置（向后兼容）----------------------
# 如果 RUSTFS_TARGETS_JSON 没设，会用下面这些：
# RUSTFS_ENDPOINT=http://rustfs.example.com:9000
# RUSTFS_ACCESS_KEY=changeme
# RUSTFS_SECRET_KEY=changeme
# RUSTFS_REGION=us-east-1
# RUSTFS_TLS_SKIP_VERIFY=false
# RUSTFS_CA_CERT=/etc/ssl/certs/ca-certificates.crt

# ============================================================
# 单目标模式的 TLS（仅在用 RUSTFS_TARGETS_JSON 时被忽略）
# ============================================================
# 方式 A（生产推荐）：把 rustfs 用的私有 CA 证书挂进 exporter
# 方式 B（仅调试）：RUSTFS_TLS_SKIP_VERIFY=true
#
# 默认指向 Debian/Ubuntu 系统 CA bundle；如系统是 RHEL/Fedora 请改为
#   /etc/pki/tls/certs/ca-bundle.crt
# RUSTFS_TLS_SKIP_VERIFY=false

# ============================================================
# 抓取频率
# ============================================================
RUSTFS_EXPORTER_SCRAPE_INTERVAL=30s

# ============================================================
# Grafana
# ============================================================
GF_ADMIN_PASS=admin