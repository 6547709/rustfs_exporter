# ============================================================
# RustFS Monitoring Stack — .env template
# ============================================================
# 复制本文件为 .env 后填入真实值：
#   cp .env.example .env && vim .env
#
# 部署在能直连 rustfs 的机器上（同一 VPC / VPN / 同主机）。

# ---------- 被监控的 rustfs ----------
# S3 endpoint（admin API 复用同地址同端口），含协议头
# 例：
#   http://10.0.50.15:9000          # 明文（仅测试）
#   https://rustfs.example.com:9000  # 生产
RUSTFS_ENDPOINT=https://10.0.50.15:9000

# admin API 复用 S3 凭证
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=VMware1!

# S3 签名 region（rustfs 不校验，但 SigV4 必需）
RUSTFS_REGION=us-east-1

# ---------- TLS ----------
# 方式 A（生产推荐）：把 rustfs 用的私有 CA 证书挂进 exporter
#   - 把 .pem 文件放到本机任意路径，如 /etc/ssl/certs/rustfs-ca.pem
#   - 设置 RUSTFS_CA_CERT_HOST_PATH 指向该文件
#   - RUSTFS_TLS_SKIP_VERIFY 留空
#
# 方式 B（仅调试）：跳过证书验证（MITM 风险）
#   - RUSTFS_TLS_SKIP_VERIFY=true
#   - RUSTFS_CA_CERT_HOST_PATH 指向任意已存在文件（compose 仍会挂载，但 exporter 不读）
#
# 默认指向 Debian/Ubuntu 系统 CA bundle；如系统是 RHEL/Fedora 请改为
#   /etc/pki/tls/certs/ca-bundle.crt
RUSTFS_TLS_SKIP_VERIFY=true
RUSTFS_CA_CERT_HOST_PATH=/etc/ssl/certs/ca-certificates.crt

# ---------- 抓取频率 ----------
# exporter 主动抓取 rustfs 的周期；VM 抓 exporter 默认也是 30s
RUSTFS_EXPORTER_SCRAPE_INTERVAL=30s

# ---------- Grafana ----------
GF_ADMIN_PASS=admin