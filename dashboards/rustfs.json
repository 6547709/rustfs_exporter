{
  "title": "RustFS",
  "uid": "rustfs-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(rustfs_health_ready, cluster)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      },
      {
        "name": "bucket",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(rustfs_replication_completed_count, bucket)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Health",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "id": 100
    },
    {
      "type": "stat",
      "title": "Storage",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "min by (component) (rustfs_health_ready{component=\"storage\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NOT READY",
                  "color": "red"
                },
                "1": {
                  "text": "READY",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "IAM",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "min by (component) (rustfs_health_ready{component=\"iam\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NOT READY",
                  "color": "red"
                },
                "1": {
                  "text": "READY",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Lock",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "min by (component) (rustfs_health_ready{component=\"lock\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NOT READY",
                  "color": "red"
                },
                "1": {
                  "text": "READY",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Exporter",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "rustfs_up",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Per-Bucket Replication (current snapshot)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "id": 101,
      "description": "6 metrics \u00d7 (cluster, bucket) combinations. Use cluster/bucket dropdowns at top to filter."
    },
    {
      "type": "stat",
      "title": "Pending Size",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "max by (cluster, bucket) (rustfs_replication_pending_bytes)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 0
        }
      },
      "description": "Use the cluster dropdown at top to filter. With All selected, shows first series only (stat panel limitation)."
    },
    {
      "type": "stat",
      "title": "Pending Objects",
      "gridPos": {
