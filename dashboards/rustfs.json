    {
      "type": "stat",
      "title": "Failed Objects",
      "gridPos": {
        "x": 8,
        "y": 10,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "max by (cluster, bucket) (rustfs_replication_failed_count)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
