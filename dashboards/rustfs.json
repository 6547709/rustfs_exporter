      "description": "Use the cluster dropdown at top to filter. With All selected, shows first series only (stat panel limitation)."
    },
    {
      "type": "stat",
      "title": "Current Bandwidth",
      "gridPos": {
        "x": 16,
        "y": 10,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "max by (cluster, bucket) (rustfs_replication_bandwidth_current_bytes)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "\u2014"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 0
        }
      },
      "description": "Use the cluster dropdown at top to filter. With All selected, shows first series only (stat panel limitation)."
    },
    {
      "type": "row",
      "title": "Replication Trend",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "id": 102
    },
    {
      "type": "timeseries",
      "title": "Pending Backlog",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rustfs_replication_pending_bytes{bucket=~\"$bucket\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 0
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Replication Throughput",
      "gridPos": {
        "x": 12,
        "y": 17,
        "w": 12,
        "h": 8
      },
      "description": "Instantaneous rate of completed_bytes (PromQL irate over 2m window). rustfs admin API current_bandwidth is unreliable (~100x lower than actual).",
      "targets": [
        {
          "expr": "irate(rustfs_replication_completed_bytes[2m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "decimals": 0,
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": 0,
                "result": {
                  "text": "0"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Replicated Total (cumulative)",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 12,
        "h": 8
      },
      "description": "Cumulative bytes successfully replicated since rustfs started. Counter, only goes up.",
      "targets": [
        {
          "expr": "rustfs_replication_completed_bytes{bucket=~\"$bucket\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          },
          "decimals": 0
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Reported Bandwidth (UNRELIABLE)",
      "gridPos": {
        "x": 12,
        "y": 25,
        "w": 12,
        "h": 8
      },
      "description": "\u26a0\ufe0f rustfs admin API current_bandwidth_bytes_per_sec underreports by ~100x. Use Replication Throughput instead.",
      "targets": [
        {
          "expr": "rustfs_replication_bandwidth_current_bytes{bucket=~\"$bucket\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "KBs",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "decimals": 1,
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": 0,
                "result": {
                  "text": "0"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Failure Rate",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "description": "Average failed objects per second over the last 5 minutes.",
      "targets": [
        {
          "expr": "delta(rustfs_replication_failed_count[5m]) / 300",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "decimals": 0
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": {
        "x": 12,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "description": "Bytes waiting in the replication queue. Current / Last minute average / Max since start.",
      "targets": [
        {
          "expr": "rustfs_replication_queue_current_bytes{bucket=~\"$bucket\"}",
          "refId": "A",
          "legendFormat": "current"
        },
        {
          "expr": "rustfs_replication_queue_last_minute_bytes{bucket=~\"$bucket\"}",
          "refId": "B",
          "legendFormat": "avg last minute"
        },
        {
          "expr": "rustfs_replication_queue_max_bytes{bucket=~\"$bucket\"}",
          "refId": "C",
          "legendFormat": "max since start"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "decimals": 0
        }
      }
    }
  ]
}