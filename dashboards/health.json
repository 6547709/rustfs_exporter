{
  "title": "RustFS / Cluster Health",
  "uid": "rustfs-health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "stat", "title": "Storage Ready", "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets": [{"expr": "rustfs_health_ready{component=\"storage\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value","options": {"0":{"text":"NOT READY","color":"red"},"1":{"text":"READY","color":"green"}}}]}}
    },
    {
      "type": "stat", "title": "IAM Ready", "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "targets": [{"expr": "rustfs_health_ready{component=\"iam\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value","options": {"0":{"text":"NOT READY","color":"red"},"1":{"text":"READY","color":"green"}}}]}}
    },
    {
      "type": "stat", "title": "Lock Ready", "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "targets": [{"expr": "rustfs_health_ready{component=\"lock\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value","options": {"0":{"text":"NOT READY","color":"red"},"1":{"text":"READY","color":"green"}}}]}}
    },
    {
      "type": "stat", "title": "Exporter", "gridPos": {"x":18,"y":0,"w":6,"h":4},
      "targets": [{"expr": "rustfs_up", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value","options": {"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}]}}
    }
  ]
}
