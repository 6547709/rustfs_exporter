{
  "title": "RustFS / Replication Trend",
  "uid": "rustfs-replication-trend",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "bucket",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(rustfs_replication_pending_bytes, bucket)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries", "title": "Pending Backlog", "gridPos": {"x":0,"y":0,"w":12,"h":8},
      "targets": [{"expr": "rustfs_replication_pending_bytes{bucket=~\"$bucket\"}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "type": "timeseries", "title": "Replication Throughput", "gridPos": {"x":12,"y":0,"w":12,"h":8},
      "description": "Average bytes replicated per second over the last 5 minutes (PromQL rate() over cumulative counter).",
      "targets": [{"expr": "rate(rustfs_replication_completed_bytes[5m])", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "type": "timeseries", "title": "Replicated Total (cumulative)", "gridPos": {"x":0,"y":8,"w":12,"h":8},
      "description": "Cumulative bytes successfully replicated since rustfs started. Counter, only goes up.",
      "targets": [{"expr": "rustfs_replication_completed_bytes{bucket=~\"$bucket\"}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity"}
        }
      }
    },
    {
      "type": "timeseries", "title": "Current Bandwidth (from admin API)", "gridPos": {"x":12,"y":8,"w":12,"h":8},
      "description": "Instantaneous replication bandwidth reported by rustfs admin (per-ARN aggregated).",
      "targets": [{"expr": "rustfs_replication_bandwidth_current_bytes{bucket=~\"$bucket\"}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "type": "timeseries", "title": "Failure Rate", "gridPos": {"x":0,"y":16,"w":12,"h":8},
      "description": "Average failed objects per second over the last 5 minutes.",
      "targets": [{"expr": "rate(rustfs_replication_failed_count[5m])", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "fixed", "fixedColor": "red"}
        }
      }
    },
    {
      "type": "timeseries", "title": "Queue Depth", "gridPos": {"x":12,"y":16,"w":12,"h":8},
      "description": "Bytes waiting in the replication queue. Current / Last minute average / Max since start.",
      "targets": [
        {"expr": "rustfs_replication_queue_current_bytes{bucket=~\"$bucket\"}",      "refId": "A", "legendFormat": "current"},
        {"expr": "rustfs_replication_queue_last_minute_bytes{bucket=~\"$bucket\"}",  "refId": "B", "legendFormat": "avg last minute"},
        {"expr": "rustfs_replication_queue_max_bytes{bucket=~\"$bucket\"}",          "refId": "C", "legendFormat": "max since start"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      }
    }
  ]
}