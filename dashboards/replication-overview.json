{
  "title": "RustFS / Replication Overview",
  "uid": "rustfs-replication-overview",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "table", "title": "Per-Bucket Replication (current snapshot)", "gridPos": {"x":0,"y":0,"w":24,"h":12},
      "targets": [
        {"expr": "rustfs_replication_pending_bytes",           "refId": "A", "format": "table", "instant": true, "hide": true},
        {"expr": "rustfs_replication_pending_count",           "refId": "B", "format": "table", "instant": true, "hide": true},
        {"expr": "rustfs_replication_completed_bytes",         "refId": "C", "format": "table", "instant": true, "hide": true},
        {"expr": "rustfs_replication_completed_count",         "refId": "D", "format": "table", "instant": true, "hide": true},
        {"expr": "rustfs_replication_failed_count",            "refId": "E", "format": "table", "instant": true, "hide": true},
        {"expr": "rustfs_replication_bandwidth_current_bytes", "refId": "F", "format": "table", "instant": true, "hide": true}
      ],
      "transformations": [
        {"id": "merge"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto", "wrapText": false}
          }
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Value (pending_bytes)"},
           "properties": [{"id": "unit", "value": "bytes"},
                          {"id": "displayName", "value": "Pending Size"},
                          {"id": "custom.cellOptions", "value": {"type": "color-background", "wrapText": false}}]},
          {"matcher": {"id": "byName", "options": "Value (pending_count)"},
           "properties": [{"id": "unit", "value": "short"},
                          {"id": "displayName", "value": "Pending Objects"}]},
          {"matcher": {"id": "byName", "options": "Value (completed_bytes)"},
           "properties": [{"id": "unit", "value": "bytes"},
                          {"id": "displayName", "value": "Replicated Total"},
                          {"id": "custom.cellOptions", "value": {"type": "color-background", "wrapText": false}}]},
          {"matcher": {"id": "byName", "options": "Value (completed_count)"},
           "properties": [{"id": "unit", "value": "short"},
                          {"id": "displayName", "value": "Replicated Objects"}]},
          {"matcher": {"id": "byName", "options": "Value (failed_count)"},
           "properties": [{"id": "unit", "value": "short"},
                          {"id": "displayName", "value": "Failed Objects"},
                          {"id": "custom.cellOptions", "value": {"type": "gauge", "mode": "gradient", "valueDisplayMode": "color"}}]},
          {"matcher": {"id": "byName", "options": "Value (bandwidth_current_bytes)"},
           "properties": [{"id": "unit", "value": "Bps"},
                          {"id": "displayName", "value": "Current Bandwidth"}]}
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": {"show": false},
        "showHeader": true
      }
    }
  ]
}